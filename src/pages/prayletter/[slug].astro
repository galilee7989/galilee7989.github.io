---
import prayletters from '../../data/prayletters.json';

export function getStaticPaths() {
  return prayletters.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{item.title}｜財團法人基督教加利利傳道會</title>
    <style>
      html, body { height: 100%; margin: 0; background: #2a2622; }
      .load {
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fcd77a;
        font-family: "Noto Sans TC", "Microsoft JhengHei", sans-serif;
        font-size: 18px;
        letter-spacing: 0.1em;
      }
      .load a { color: #fff; text-decoration: underline; }
    </style>
  </head>
  <body>
    <div class="load" id="load">PDF 載入中，請稍候…</div>
    <script is:inline define:vars={{ pdf: item.pdf }}>
      fetch(pdf)
        .then(function (r) { if (!r.ok) throw new Error(r.status); return r.blob(); })
        .then(function (b) { window.location.replace(URL.createObjectURL(b)); })
        .catch(function () {
          document.getElementById('load').innerHTML =
            'PDF 載入失敗，<a href="' + pdf + '">點此開啟</a>';
        });
    </script>
  </body>
</html>
